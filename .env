# =========================================================
# ENV TABANLI SISTEM KULLANICILARI VE ROLLER
# AMAC:
# - ADMIN KULLANICISINA COK GENIS YETKI VER
# - TEST_USER KULLANICISINI NORMAL / YENI KULLANICI GIBI TUT
# - .ENV DOSYASINA BAKINCA KIME HANGI YETKI VERILDIGI TURKCE
#   ACIKLAMALARLA HEMEN ANLASILSIN
# - BU DOSYADAKI SIFRELER PROJEDE ACIK OLARAK OKUNABILIR
#   OLABILIR, ANCAK SISTEM BOOT ANINDA BU SIFRELERI HASHLEMELI,
#   VERITABANINA VEYA KALICI KAYDA ASLA DUZ METIN OLARAK YAZMAMALI
# =========================================================

ENV_USERS_ENABLED=true
# true ise sistem acilisinda .env icinden tanimlanan kullanicilar okunur.

ENV_USERS_SYNC_ON_BOOT=true
# true ise uygulama baslarken bu kullanicilar sisteme otomatik eklenir
# veya var olan kayitlar buna gore guncellenir.

ENV_PASSWORDS_MUST_BE_HASHED_ON_BOOT=true
# ZORUNLU KURAL:
# .env icindeki sifreler sadece baslangic girdisi olarak kullanilsin.
# UYGULAMA BOOT ANINDA BU SIFRELERI HASHLESIN.
# DUZ METIN SIFRE VERITABANINA, KV'YE, FS'YE VEYA KALICI LOG'A YAZILMASIN.

ENV_PASSWORD_HASH_STRATEGY=bcrypt
# Boot sirasinda sifre hashlemek icin kullanilacak yontem.
# Ornek: bcrypt, argon2

ENV_PASSWORD_HASH_ROUNDS=12
# Hash maliyet ayari.
# Boot sirasinda sifreler bu ayarla hashlenmeli.


# =========================================================
# 1) ANA YONETICI KULLANICISI
# =========================================================

# Not: Mevcut ADMIN_USERNAME ve ADMIN_PASSWORD anahtarlari korunur.
# Bu blok yalnizca yeni rol/yetki davranis alanlarini ekler.

ENV_ADMIN_ROLE=admin
# Rol: admin
# Bu rol en yuksek sistem yetkisini temsil eder.

ENV_ADMIN_STATUS=active
# active = hesap aktif
# disabled = hesap pasif

ENV_ADMIN_IS_SYSTEM_USER=true
# true ise bu hesap normal kullanici degil, sistem yonetim hesabi gibi ele alinir.

ENV_ADMIN_IS_SEEDED=true
# true ise bu hesap elle degil, sistem tarafindan .env uzerinden olusturulur.

ENV_ADMIN_NOTES=ANA_YONETICI_HESABI
# Bu alan sadece aciklama icindir.


# -------------------------
# ADMIN YETKILERI
# -------------------------

ENV_ADMIN_CAN_ACCESS_ADMIN=true
# Admin panellerine girebilir.

ENV_ADMIN_CAN_ACCESS_SUPER_ADMIN_AREAS=true
# En ust duzey yonetim ekranlarina girebilir.
# Ornek: sistem ayarlari, gizli yonetim alanlari, ileri seviye kontrol ekranlari.

ENV_ADMIN_CAN_MANAGE_USERS=true
# Kullanici ekleyebilir, silebilir, duzenleyebilir.

ENV_ADMIN_CAN_ASSIGN_ROLES=true
# Kullanicilara admin / user gibi roller atayabilir.

ENV_ADMIN_CAN_EDIT_PERMISSIONS=true
# Yetki setlerini degistirebilir.
# Ornek: bir kullanicinin hangi ekranlara girecegini belirleyebilir.

ENV_ADMIN_CAN_IMPERSONATE_USERS=true
# Test amacli olarak baska bir kullanicinin deneyimini gorebilir.

ENV_ADMIN_CAN_VIEW_ALL_USER_PROFILES=true
# Tum kullanicilarin profil ve durum bilgilerini gorebilir.

ENV_ADMIN_CAN_VIEW_ALL_USAGE=true
# Tum kullanicilarin kullanim gecmisini gorebilir.

ENV_ADMIN_CAN_VIEW_ALL_LOGS=true
# Sistem loglarini gorebilir.

ENV_ADMIN_CAN_VIEW_AUDIT_LOGS=true
# Yetki degisikligi, kritik islem ve yonetim hareketlerini gorebilir.

ENV_ADMIN_CAN_VIEW_SECURITY_EVENTS=true
# Guvenlik olaylarini gorebilir.
# Ornek: basarisiz giris denemeleri, rate limit tetikleri, supheli istekler.

ENV_ADMIN_CAN_MANAGE_CREDITS=true
# Kredi ekleyebilir, silebilir, duzenleyebilir.

ENV_ADMIN_CAN_OVERRIDE_CREDIT_LIMITS=true
# Normal kredi kisitlarini gecersiz kilabilir.

ENV_ADMIN_CAN_REFUND_CREDITS=true
# Kullaniciya kredi iadesi yapabilir.

ENV_ADMIN_CAN_EDIT_PRICING=true
# Fiyatlandirma ayarlarini degistirebilir.

ENV_ADMIN_CAN_EDIT_USD_TO_CREDIT_RATE=true
# "1 USD = Kac Kredi?" degerini degistirebilir.

ENV_ADMIN_CAN_MANAGE_BILLING=true
# Faturalama / bakiye / ucretlendirme alanlarini yonetebilir.

ENV_ADMIN_CAN_MANAGE_MODELS=true
# Model listesi, model aktifligi ve model izinlerini yonetebilir.

ENV_ADMIN_CAN_EDIT_MODEL_ALLOWLIST=true
# Hangi modellerin kullanilabilecegini belirleyebilir.

ENV_ADMIN_CAN_EDIT_AI_SETTINGS=true
# AI genel ayarlari, timeout, limit, cache gibi alanlari yonetebilir.

ENV_ADMIN_CAN_EDIT_PROVIDER_SETTINGS=true
# Provider veya me.puter baglantisi ile ilgili sistem ayarlarini yonetebilir.

ENV_ADMIN_CAN_RUN_ALL_AI_FEATURES=true
# Tum AI ozelliklerini kullanabilir.

ENV_ADMIN_CAN_USE_CHAT=true
# Sohbet ozelligini kullanabilir.

ENV_ADMIN_CAN_USE_IMAGE=true
# Gorsel uretim ozelligini kullanabilir.

ENV_ADMIN_CAN_USE_VIDEO=true
# Video uretim ozelligini kullanabilir.

ENV_ADMIN_CAN_USE_PHOTO_TO_VIDEO=true
# Fotograftan video ozelligini kullanabilir.

ENV_ADMIN_CAN_USE_TTS=true
# Metinden sese donusturme ozelligini kullanabilir.

ENV_ADMIN_CAN_USE_MUSIC=true
# Muzik ozelligini kullanabilir.

ENV_ADMIN_CAN_SEE_HIDDEN_FEATURES=true
# Normal kullaniciya gosterilmeyen gelistirme veya beta alanlarini gorebilir.

ENV_ADMIN_CAN_ENABLE_DISABLE_FEATURES=true
# Ozellik ac/kapat yapabilir.

ENV_ADMIN_CAN_MANAGE_STORAGE=true
# Uretilen dosyalarin depolanmasi ile ilgili islemleri yonetebilir.

ENV_ADMIN_CAN_DELETE_ANY_ASSET=true
# Herhangi bir kullaniciya ait gorsel/ses/video dosyasini silebilir.

ENV_ADMIN_CAN_RETRY_FAILED_JOBS=true
# Basarisiz AI job'larini yeniden calistirabilir.

ENV_ADMIN_CAN_CANCEL_ANY_JOB=true
# Her kullanicinin aktif job'ini iptal edebilir.

ENV_ADMIN_CAN_VIEW_JOB_QUEUE=true
# Bekleyen/calisan AI is kuyrugunu gorebilir.

ENV_ADMIN_CAN_EDIT_RATE_LIMITS=true
# Hiz limiti ayarlarini degistirebilir.

ENV_ADMIN_CAN_BYPASS_RATE_LIMITS=true
# Gerekirse kendi hesabi icin hiz limitini asabilir.

ENV_ADMIN_CAN_EXPORT_DATA=true
# Rapor veya kullanim verilerini disa aktarabilir.

ENV_ADMIN_CAN_ACCESS_INTERNAL_DEBUG=true
# Ic debug ekranlarina girebilir.

ENV_ADMIN_CAN_MANAGE_ENV_USERS=true
# .env uzerinden gelen kullanicilari yonetebilir.

ENV_ADMIN_CAN_DELETE_SYSTEM_USERS=false
# Sistem kullanicilarini tamamen silme yetkisini kapali tuttum.
# Bu, yanlislikla ana yonetici hesabinin silinmesini onlemek icin guvenli bir tercih.

ENV_ADMIN_CAN_DESTROY_SYSTEM_DATA=false
# En tehlikeli yetkiyi varsayilan olarak kapali tut.
# Cok gerekirse ayri bir super_admin katmanina ac.


