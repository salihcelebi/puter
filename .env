# =========================================================
# 3) ROL DAVRANISI ILE ILGILI GENEL KURALLAR
# =========================================================

ENV_ROLE_ENFORCEMENT_MODE=backend_strict
# En onemli alanlardan biri.
# Yetkiler sadece arayuzde gizleme ile degil, backend tarafinda da zorunlu uygulanmali.

ENV_HIDE_ADMIN_UI_FROM_NON_ADMINS=true
# Admin olmayan kullanicidan admin menu ve admin sayfalari gizlenir.

ENV_BLOCK_ADMIN_API_FOR_NON_ADMINS=true
# Admin olmayan kullanici admin API'lerine backend tarafinda da sokulmaz.

ENV_LOG_ROLE_DENIALS=true
# Yetkisiz erisim denemeleri loglansin.

ENV_REQUIRE_PERMISSION_CHECK_ON_ALL_AI_ACTIONS=true
# Chat, image, video, tts gibi tum AI islemlerinde izin kontrolu yap.

ENV_REQUIRE_PERMISSION_CHECK_ON_ADMIN_ACTIONS=true
# Tum admin islemlerinde izin kontrolu yap.

ENV_SHOW_ROLE_LABELS_IN_ADMIN_PANEL=true
# /admin/kullanicilar ekraninda her kullanicinin rolu gorunsun.

ENV_SHOW_PERMISSION_SUMMARY_IN_ADMIN_PANEL=true
# /admin/kullanicilar ekraninda kullanicinin temel yetki ozeti gorunsun.


