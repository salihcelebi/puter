# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: Public URL of this app.
APP_URL="MY_APP_URL"

# Auth JWT secret. Must be at least 32 characters.
JWT_SECRET="replace-with-very-long-random-secret"

# Bootstrap admin credentials (required on server startup)
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="change-this-password"

# Optional admin e-mail for bootstrap account
ADMIN_EMAIL="admin@example.com"

# Backend auth/API service URL for frontend deployments (Option A).
# Example: https://my-backend.example.com
VITE_API_BASE_URL=""
